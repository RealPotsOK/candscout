{
  "id": "xgboost",
  "label": "XGBoost",
  "complexity_rank": 50,
  "complexity_group": "Classical ML",
  "description": "Gradient-boosted tree model using tabular rolling/candle features.",
  "family": "xgb",
  "model_type": "xgboost",
  "backend": "xgboost",
  "preset": "recommended_v1",
  "actions": {
    "train": [
      "download",
      "xgb-experiment"
    ],
    "visualize": [
      "xgb-visualize",
      "reports-index"
    ],
    "simulate": [
      "xgb-sim",
      "xgb-sim-visualize",
      "reports-index"
    ],
    "full": [
      "download",
      "xgb-experiment",
      "xgb-visualize",
      "xgb-sim",
      "xgb-sim-visualize",
      "reports-index"
    ]
  },
  "links": {
    "model": "/xgb/{DATA_SOURCE}/{SYMBOL}/{INTERVAL}/visualization.html",
    "simulation": "/sim/xgb/{DATA_SOURCE}/{SYMBOL}/{INTERVAL}/visualization.html"
  },
  "defaults": {
    "DATA_SOURCE": "binance",
    "SYMBOL": "SOLUSDT",
    "INTERVAL": "3m",
    "START": "2023-11-18T00:00:00Z",
    "END": "2026-05-18T00:00:00Z",
    "SPLIT": "0.9",
    "EDGE": "0",
    "FEE": "0.0001",
    "THRESHOLD": "0.55",
    "EXIT_THRESHOLD": "0.48",
    "POSITION_MODE": "hold",
    "XGB_TRAINER_ENV": "env/trainers/xgboost.env",
    "XGB_N_ESTIMATORS": "400",
    "XGB_MAX_DEPTH": "3",
    "XGB_LEARNING_RATE": "0.03",
    "XGB_SUBSAMPLE": "0.8",
    "XGB_COLSAMPLE_BYTREE": "0.8",
    "XGB_MIN_CHILD_WEIGHT": "10",
    "XGB_REG_LAMBDA": "2.0",
    "XGB_REG_ALPHA": "0.05",
    "XGB_GAMMA": "0.0",
    "XGB_CLASS_WEIGHT_MODE": "balanced",
    "XGB_SEED": "67",
    "XGB_DEVICE": "cuda",
    "SIM_STARTING_CASH": "10000",
    "SIM_MIN_INVEST": "2500",
    "SIM_MAX_INVEST": "8000",
    "SIM_CONFIDENCE_MULTIPLIER": "1.0",
    "TRADE_MODE": "long_only",
    "SHORT_ENTRY_THRESHOLD": "0.55",
    "SHORT_EXIT_THRESHOLD": "0.48",
    "SIM_MAX_SHORT_INVEST": "8000",
    "ALLOW_FLIP_POSITION": "0",
    "BORROW_FEE": "0",
    "SIM_SLIPPAGE": "0",
    "STOP_LOSS": "0.02",
    "TAKE_PROFIT": "0.04",
    "MAX_HOLD_BARS": "60",
    "LEVERAGE": "1",
    "LIQUIDATION_SIMULATION": "off",
    "SIM_SHORT_CONFIDENCE_MULTIPLIER": "3.0",
    "SHORT_EDGE": "0"
  },
  "fields": [
    {
      "name": "DATA_SOURCE",
      "label": "Data Source",
      "type": "select",
      "options": [
        "binance",
        "yahoo"
      ],
      "section": "data"
    },
    {
      "name": "SYMBOL",
      "label": "Symbol",
      "type": "text",
      "section": "data"
    },
    {
      "name": "INTERVAL",
      "label": "Interval",
      "type": "text",
      "section": "data"
    },
    {
      "name": "START",
      "label": "Start UTC",
      "type": "text",
      "section": "data"
    },
    {
      "name": "END",
      "label": "End UTC",
      "type": "text",
      "section": "data"
    },
    {
      "name": "SPLIT",
      "label": "Train Split",
      "type": "number",
      "step": "0.01",
      "section": "data"
    },
    {
      "name": "EDGE",
      "label": "Label Edge",
      "type": "number",
      "step": "0.0001",
      "section": "data"
    },
    {
      "name": "SHORT_EDGE",
      "label": "Short Label Edge",
      "type": "number",
      "step": "0.0001",
      "section": "data"
    },
    {
      "name": "TRADE_MODE",
      "label": "Trade Mode",

XGB_PREDICTIONS_OUT ?= data/reports/xgb/$(DATA_SOURCE)/$(SYMBOL)/$(INTERVAL)/predictions.parquet
XGB_VISUALIZATION_OUT ?= data/reports/xgb/$(DATA_SOURCE)/$(SYMBOL)/$(INTERVAL)/visualization.html
XGB_SIM_REPORT ?= models/sim/xgb/$(DATA_SOURCE)/$(SYMBOL)/$(INTERVAL)/bank_report.json

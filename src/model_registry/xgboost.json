      "type": "number",
      "step": "10",
      "section": "model"
    },
    {
      "name": "XGB_MAX_DEPTH",
      "label": "Max Depth",
      "type": "number",
      "step": "1",
      "section": "model"
    },
    {
      "name": "XGB_LEARNING_RATE",
      "label": "Learning Rate",
      "type": "number",
      "step": "0.01",
      "section": "model"
    },
    {
      "name": "XGB_SUBSAMPLE",
      "label": "Subsample",
      "type": "number",
      "step": "0.05",
      "section": "model"
    },
    {
      "name": "XGB_COLSAMPLE_BYTREE",
      "label": "Column Sample",

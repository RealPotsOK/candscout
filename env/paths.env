NN_VISUALIZATION_OUT ?= data/reports/nn/$(NN_MODEL_TYPE)/$(DATA_SOURCE)/$(SYMBOL)/$(INTERVAL)/visualization.html
XGB_FEATURES_DATA ?= data/features/xgb/$(DATA_SOURCE)/$(SYMBOL)/$(INTERVAL)/features.parquet

# Sequence neural net defaults.
NN_BACKEND ?= torch
NN_DEVICE ?= cuda
NN_MODEL_TYPE ?= cnn
NN_LOOKBACK ?= 50
NN_SEQUENCE_FEATURE_SET ?= basic
NN_CNN_FILTERS ?= 16,32
NN_CNN_KERNEL_SIZES ?= 5,3
NN_LSTM_HIDDEN_SIZE ?= 64
NN_LSTM_LAYERS ?= 1
NN_LSTM_DROPOUT ?= 0.0
NN_GRU_HIDDEN_SIZE ?= 64
NN_GRU_LAYERS ?= 1
NN_GRU_DROPOUT ?= 0.0
NN_TRANSFORMER_D_MODEL ?= 64
NN_TRANSFORMER_HEADS ?= 4
NN_TRANSFORMER_LAYERS ?= 2
NN_TRANSFORMER_FF_DIM ?= 128
NN_TRANSFORMER_DROPOUT ?= 0.1
NN_HIDDEN_LAYERS ?= 32,16
NN_LR ?= 0.0005
NN_EPOCHS ?= 100
NN_BATCH_SIZE ?= 2048
NN_L2 ?= 0.0005
NN_CLASS_WEIGHT_MODE ?= balanced
NN_SEED ?= 67

# Bank simulation defaults.
SIM_START ?=
SIM_DURATION ?=
# Fallback for old prediction files without dataset_split. New files select
# explicit test rows, and this tracks the configured chronological split.
SIM_DEFAULT_TEST_FRACTION ?= $(shell $(PYTHON) -c 's=float("$(SPLIT)"); print(f"{1.0-s:.12g}")')
SIM_POSITION_MODE ?= live
SIM_STARTING_CASH ?= 10000
SIM_MIN_INVEST ?= 2500
SIM_MAX_INVEST ?= 8000
SIM_MAX_SHORT_INVEST ?= $(SIM_MAX_INVEST)
TRADE_MODE ?= long_only
SHORT_ENTRY_THRESHOLD ?= 0.55
SHORT_EXIT_THRESHOLD ?= 0.48
ALLOW_FLIP_POSITION ?= 0
BORROW_FEE ?= 0
LEVERAGE ?= 1
LIQUIDATION_SIMULATION ?= off
SIM_CONFIDENCE_MULTIPLIER ?= 1.0
SIM_SHORT_CONFIDENCE_MULTIPLIER ?= 3.0
SIM_SLIPPAGE ?= 0
SIM_SPREAD_PCT ?= 0.00015
SIM_ACTIVITY_BUCKET ?= auto
SIM_MARKER_SIZE_BASIS ?= usd
VIS_BASELINE_MA_WINDOW ?= 20
VIS_MAX_BROWSER_POINTS ?= 20000
SIM_BASELINE_MA_WINDOWS ?= 20,50
SIM_REPORT ?= models/sim/lr/$(DATA_SOURCE)/$(SYMBOL)/$(INTERVAL)/bank_report.json
SIM_TRADES ?= data/reports/sim/lr/$(DATA_SOURCE)/$(SYMBOL)/$(INTERVAL)/bank_trades.csv
SIM_LONG_SHORT_REPORT ?= models/sim/lr/$(DATA_SOURCE)/$(SYMBOL)/$(INTERVAL)/bank_report_long_short.json
SIM_LONG_SHORT_TRADES ?= data/reports/sim/lr/$(DATA_SOURCE)/$(SYMBOL)/$(INTERVAL)/bank_trades_long_short.csv
SIM_VISUALIZATION_OUT ?= data/reports/sim/lr/$(DATA_SOURCE)/$(SYMBOL)/$(INTERVAL)/visualization.html
NN_SIM_REPORT ?= models/sim/nn/$(NN_MODEL_TYPE)/$(DATA_SOURCE)/$(SYMBOL)/$(INTERVAL)/bank_report.json
NN_SIM_TRADES ?= data/reports/sim/nn/$(NN_MODEL_TYPE)/$(DATA_SOURCE)/$(SYMBOL)/$(INTERVAL)/bank_trades.csv
NN_SIM_LONG_SHORT_REPORT ?= models/sim/nn/$(NN_MODEL_TYPE)/$(DATA_SOURCE)/$(SYMBOL)/$(INTERVAL)/bank_report_long_short.json
NN_SIM_LONG_SHORT_TRADES ?= data/reports/sim/nn/$(NN_MODEL_TYPE)/$(DATA_SOURCE)/$(SYMBOL)/$(INTERVAL)/bank_trades_long_short.csv
NN_SIM_VISUALIZATION_OUT ?= data/reports/sim/nn/$(NN_MODEL_TYPE)/$(DATA_SOURCE)/$(SYMBOL)/$(INTERVAL)/visualization.html

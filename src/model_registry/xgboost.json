      "section": "trading",
      "options": [
        "long_only",
        "short_only",
        "long_short"
      ]
    },
    {
      "name": "THRESHOLD",
      "label": "Long Entry Threshold",
      "type": "number",
      "section": "trading",
      "step": "0.01"
    },
    {
      "name": "EXIT_THRESHOLD",
      "label": "Long Exit Threshold",
      "type": "number",
      "section": "trading",
      "step": "0.01"
    },
    {

# Torch-backed sequence CNN trainer preset.
NN_BACKEND ?= torch
NN_DEVICE ?= cuda
NN_MODEL_TYPE ?= cnn
NN_LOOKBACK ?= 50
NN_CNN_FILTERS ?= 16,32
NN_CNN_KERNEL_SIZES ?= 5,3
NN_HIDDEN_LAYERS ?= 32,16
NN_LR ?= 0.0005
NN_EPOCHS ?= 100
NN_BATCH_SIZE ?= 2048
NN_L2 ?= 0.0005
NN_CLASS_WEIGHT_MODE ?= balanced
NN_SEED ?= 67

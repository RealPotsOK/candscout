# XGBoost tabular tree model defaults.
XGB_TRAINER_ENV ?= env/trainers/xgboost.env
XGB_N_ESTIMATORS ?= 400
XGB_MAX_DEPTH ?= 3
XGB_LEARNING_RATE ?= 0.03
XGB_SUBSAMPLE ?= 0.8
XGB_COLSAMPLE_BYTREE ?= 0.8
XGB_MIN_CHILD_WEIGHT ?= 10
XGB_REG_LAMBDA ?= 2.0
XGB_REG_ALPHA ?= 0.05
XGB_GAMMA ?= 0.0
XGB_TREE_METHOD ?= hist
XGB_DEVICE ?= cuda
XGB_N_JOBS ?= 0
XGB_CLASS_WEIGHT_MODE ?= balanced
XGB_POS_WEIGHT ?=
XGB_SEED ?= 67

# Torch-backed sequence LSTM trainer preset.
NN_BACKEND ?= torch
NN_DEVICE ?= cuda
NN_MODEL_TYPE ?= lstm
NN_LOOKBACK ?= 70
NN_SEQUENCE_FEATURE_SET ?= technical
NN_LSTM_HIDDEN_SIZE ?= 64
NN_LSTM_LAYERS ?= 1
NN_LSTM_DROPOUT ?= 0.0
NN_HIDDEN_LAYERS ?= 32
NN_LR ?= 0.0005
NN_EPOCHS ?= 80
NN_BATCH_SIZE ?= 2048
NN_L2 ?= 0.0005
NN_CLASS_WEIGHT_MODE ?= balanced
NN_SEED ?= 67
# LSTM default target is plain next-candle up/down.
EDGE ?= 0

# Live paper-trading server defaults.
# Copy to .env with: make setup
SYMBOL=SOLUSDT
INTERVAL=15m
BINANCE_BASE_URL=https://api.binance.com

STARTING_CASH=100
FEE=0.0001
SLIPPAGE=0
ENTRY_THRESHOLD=0.55
EXIT_THRESHOLD=0.48
TRADE_MODE=long_only
SHORT_ENTRY_THRESHOLD=0.55
SHORT_EXIT_THRESHOLD=0.48
STOP_LOSS=0.1
TAKE_PROFIT=0.1
MAX_HOLD_BARS=60
MAX_INVEST=m
MAX_SHORT_INVEST=m
ALLOW_FLIP_POSITION=false
BORROW_FEE=0
LEVERAGE=1
LIQUIDATION_SIMULATION=off
MIN_INVEST=1
CONFIDENCE_MULTIPLIER=1.0

# Coinbase real-money execution. Safe defaults do not place real orders.
# Keep credentials only in ignored env files such as live_sim/env/active.env
# or repo-root env/local.env. Ed25519 base64 secrets are easiest for .env files.
EXECUTION_MODE=paper
REAL_TRADING_ENABLED=false
REAL_REQUIRE_MANUAL_ARM=true
REAL_MAX_TOTAL_USD=20
REAL_MAX_ORDER_USD=5
REAL_MIN_ORDER_USD=1
COINBASE_PRODUCT_ID=SOL-USD
COINBASE_API_KEY=
COINBASE_API_SECRET=
COINBASE_TIMEOUT=10
REAL_ARM_TOKEN=
REAL_ORDER_STATUS_POLLS=5
REAL_ORDER_STATUS_DELAY_SECONDS=0.75

MODEL_PATH=/app/state/model.npz
DB_PATH=/app/state/live_sim.db
RESET_ON_START=false
ALLOW_RESET_API=false
POLL_ON_START=true
POLL_DELAY_SECONDS=8
KLINE_LIMIT_BUFFER=8
CATCHUP_ENABLED=true
CATCHUP_SPREAD_PCT=0.00015
# Zero means replay every missing completed candle, with no bar limit.
CATCHUP_MAX_BARS=0
CATCHUP_RETRY_SECONDS=60

# Rolling retrain. Times are UTC. RETRAIN_FREQUENCY uses h/d/w/m,
# where m means month for this setting, e.g. 10h, 3d, 1w, 1m.
RETRAIN_ENABLED=true
RETRAIN_TIME_UTC=04:00
RETRAIN_FREQUENCY=1d
RETRAIN_LOOKBACK_DAYS=913
RETRAIN_TRAIN_START=
RETRAIN_TRAIN_END=
RETRAIN_ON_START=false
RETRAIN_KEEP_RUNS=10
RETRAIN_CACHE_DIR=/app/state/downloads
TRAINING_RUNS_DIR=/app/state/training_runs

# Fresh sequence model training settings used by the retrain scheduler.
TRAIN_MODEL_TYPE=cnn
TRAIN_BACKEND=torch
TRAIN_DEVICE=cuda
TRAIN_LOOKBACK=35
TRAIN_SEQUENCE_FEATURE_SET=basic
TRAIN_EDGE=0.0003
TRAIN_SPLIT=0.95
TRAIN_USE_FULL_WINDOW=true
TRAIN_CNN_FILTERS=12,24
TRAIN_CNN_KERNEL_SIZES=5,3
TRAIN_LSTM_HIDDEN_SIZE=64
TRAIN_LSTM_LAYERS=1
TRAIN_LSTM_DROPOUT=0.0
TRAIN_GRU_HIDDEN_SIZE=64
TRAIN_GRU_LAYERS=1
TRAIN_GRU_DROPOUT=0.0
TRAIN_TRANSFORMER_D_MODEL=64
TRAIN_TRANSFORMER_HEADS=4
TRAIN_TRANSFORMER_LAYERS=2
TRAIN_TRANSFORMER_FF_DIM=128
TRAIN_TRANSFORMER_DROPOUT=0.1
TRAIN_HIDDEN_LAYERS=24,12
TRAIN_LR=0.001
TRAIN_EPOCHS=120
TRAIN_BATCH_SIZE=2048
TRAIN_L2=0.0001
TRAIN_DECISION_THRESHOLD=0.55
TRAIN_THRESHOLD_GRID=0.50,0.55,0.60,0.65,0.70,0.75,0.80,0.85,0.90,0.95,0.99
TRAIN_OPTIMIZE_METRIC=f1_y1
TRAIN_CLASS_WEIGHT_MODE=balanced
TRAIN_SEED=41

# Torch cache/runtime safety for Docker containers running as a host UID.
HOME=/app/state
USER=cryptopred
LOGNAME=cryptopred
XDG_CACHE_HOME=/app/state/.cache
TORCH_HOME=/app/state/.cache/torch
TORCHINDUCTOR_CACHE_DIR=/app/state/.cache/torchinductor
TRITON_CACHE_DIR=/app/state/.cache/triton
TORCHDYNAMO_DISABLE=1

HOST=0.0.0.0
PORT=8080
HOST_PORT=8080
HOST_UID=1000
HOST_GID=1000

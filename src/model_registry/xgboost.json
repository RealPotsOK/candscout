      "section": "trading",
      "step": "1"
    },
    {
      "name": "SIM_MAX_INVEST",
      "label": "Max Long Trade",
      "type": "text",
      "section": "trading"
    },
    {
      "name": "SIM_MAX_SHORT_INVEST",
      "label": "Max Short Trade",
      "type": "text",
      "section": "trading"
    },
    {
      "name": "SIM_CONFIDENCE_MULTIPLIER",
      "label": "Confidence Multiplier",
      "type": "number",
      "section": "trading",
      "step": "0.1"
    },
    {
      "name": "SIM_SHORT_CONFIDENCE_MULTIPLIER",

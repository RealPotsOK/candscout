# Torch encoder-only Transformer trainer preset.
NN_BACKEND ?= torch
NN_DEVICE ?= cuda
NN_MODEL_TYPE ?= transformer
NN_LOOKBACK ?= 70
NN_SEQUENCE_FEATURE_SET ?= technical
NN_TRANSFORMER_D_MODEL ?= 64
NN_TRANSFORMER_HEADS ?= 4
NN_TRANSFORMER_LAYERS ?= 2
NN_TRANSFORMER_FF_DIM ?= 128
NN_TRANSFORMER_DROPOUT ?= 0.1
NN_HIDDEN_LAYERS ?= 32
NN_LR ?= 0.0005
NN_EPOCHS ?= 80
NN_BATCH_SIZE ?= 2048
NN_L2 ?= 0.0005
NN_CLASS_WEIGHT_MODE ?= balanced
NN_SEED ?= 67
EDGE ?= 0

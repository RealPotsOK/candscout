# Runtime and project publishing defaults.
PYTHON ?= ./.venv/bin/python
PIP ?= ./.venv/bin/pip
PROJECT_NAME ?= candscout
GITHUB_REPO ?= candscout
COMMIT_MSG ?= organize candscout project
AUTO_SAVE_RUN ?= 1
RUNS_ROOT ?= models/runs
CURRENT_ROOT ?= models/current
ASSET_ENV ?= env/assets/solusdt_3m.env
TRAINER_ENV ?= env/trainers/cnn_torch.env
LR_TRAINER_ENV ?= env/trainers/lr_numpy.env
XGB_TRAINER_ENV ?= env/trainers/xgboost.env
